{
  "manifest_version": 3,
  "name": "UnColor",
  "version": "1.0.0",
  "description": "Entfernt alle Farb-Tags wie {color} oder {color:#000000} aus eingefügtem Text.",
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "action": {
    "default_title": "UnColor",
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon.svg"
  },
  "permissions": ["scripting", "activeTab", "clipboardWrite"],
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "clean-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Markierten Text bereinigen und kopieren"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "uncolor@local.addon",
      "strict_min_version": "115.0"
    }
  }
}
