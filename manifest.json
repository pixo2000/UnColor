{
  "manifest_version": 3,
  "name": "UnColor",
  "version": "1.0.0",
  "description": "Entfernt Jira-Farb-Tags wie {color} oder {color:#000000}, die Text unleserlich machen. Markieren, Hotkey, fertig kopiert.",
  "author": "pixo2000",
  "homepage_url": "https://github.com/pixo2000/UnColor",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "UnColor",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "permissions": ["scripting", "activeTab", "clipboardWrite"],
  "background": {
    "scripts": ["background.js"]
  },
  "commands": {
    "clean-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Markierten Text bereinigen und kopieren"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "uncolor@pixo2000",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
